{
  "name": "da-hai-lao-b",
  "version": "0.4.2",
  "private": true,
  "description": "\u5927\u6d77\u6488\uff22 - AI Photo Sorter",
  "author": "Local Developer",
  "main": "dist/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:legacy": "concurrently -k \"npm:dev:*\"",
    "dev:main": "tsup src/main/index.ts --format cjs --out-dir dist/main --watch --silent --external electron --external better-sqlite3 --external sharp --external onnxruntime-node --external electron-updater --external fs-extra --external uuid",
    "dev:preload": "tsup src/preload/index.ts --format cjs --out-dir dist/preload --watch --silent --external electron",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "dev:app": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "node scripts/build.mjs",
    "build:legacy": "npm run clean && npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsup src/main/index.ts --format cjs --out-dir dist/main --external electron --external better-sqlite3 --external sharp --external onnxruntime-node --external electron-updater --external fs-extra --external uuid",
    "build:preload": "tsup src/preload/index.ts --format cjs --out-dir dist/preload --external electron --external electron-updater",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "clean": "rimraf dist out",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:accuracy": "node scripts/accuracy-test.mjs",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "release:check": "node scripts/release-check.mjs",
    "dist:win": "npm run build && electron-builder --win nsis:x64",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "release:check-sign": "node -e \"const required=['CSC_LINK','CSC_KEY_PASSWORD']; const missing=required.filter((key)=>!process.env[key]); if (missing.length) { console.log('\u26a0\ufe0f \u5c1a\u672a\u8a2d\u5b9a Windows \u7a0b\u5f0f\u78bc\u7c3d\u7ae0\u74b0\u5883\u8b8a\u6578: '+missing.join(', ')); console.log('\u8acb\u5728\u767c\u4f48\u524d\u8a2d\u5b9a\u6191\u8b49\u5f8c\u518d\u4f7f\u7528 release:win:with-sign\u3002'); } else { console.log('\u2705 \u5075\u6e2c\u5230\u7c3d\u7ae0\u74b0\u5883\uff0c\u5c07\u5728\u767c\u4f48\u6642\u81ea\u52d5\u5957\u7528\u3002'); }\"",
    "release:win": "npm run release:check && npm run dist:win",
    "release:win:with-sign": "npm run release:check && npm run release:check-sign && npm run dist:win",
    "download-models": "node scripts/download-models.mjs",
    "postinstall": "node scripts/download-models.mjs && electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.local.dahailao-b",
    "productName": "\u5927\u6d77\u6488\uff22",
    "copyright": "Copyright \u00a9 2024",
    "icon": "resources/logo_new.png",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "package.json",
      "node_modules/**",
      "!node_modules/**/{test,tests,__tests__,docs,examples,example,doc}/**",
      "!node_modules/**/*.md",
      "!**/*.test.ts",
      "!**/*.test.tsx",
      "!tests/**",
      "models/**"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/sharp/**",
      "node_modules/onnxruntime-node/**",
      "node_modules/onnxruntime-common/**",
      "node_modules/electron-updater/**"
    ],
    "extraResources": [
      {
        "from": "resources/logo_new.png",
        "to": "logo_new.png"
      },
      {
        "from": "models",
        "to": "models",
        "filter": [
          "**/*.onnx"
        ]
      }
    ],
    "win": {
      "icon": "resources/logo_new.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "da-hai-lao-b-${version}-Setup.${ext}"
    },
    "mac": {
      "icon": "resources/logo_new.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.photography",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "icon": "resources/logo_new.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "samulee003",
        "repo": "child-picture-select"
      }
    ],
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "\u5927\u6d77\u6488\uff22"
    },
    "extraMetadata": {
      "main": "dist/main/index.cjs"
    }
  },
  "dependencies": {
    "onnxruntime-node": "^1.20.1",
    "better-sqlite3": "^11.7.0",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^2.2.7",
    "sharp": "^0.33.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.5.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "icon-gen": "^5.0.0",
    "jsdom": "^28.1.0",
    "node-gyp": "^11.5.0",
    "node-releases": "^2.0.27",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "svg-to-ico": "^1.1.0",
    "svg2ico": "^1.0.35",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "wait-on": "^8.0.2"
  }
}