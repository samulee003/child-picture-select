{
  "name": "da-hai-lao-b",
  "version": "0.2.8",
  "private": true,
  "description": "大海撈Ｂ - AI Photo Sorter",
  "author": "Local Developer",
  "main": "dist/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:legacy": "concurrently -k \"npm:dev:*\"",
    "dev:main": "tsup src/main/index.ts --format cjs --out-dir dist/main --watch --silent --external electron --external better-sqlite3 --external sharp --external canvas --external @tensorflow/tfjs-backend-wasm --external @tensorflow/tfjs --external @vladmandic/face-api --external electron-updater --external fs-extra --external uuid",
    "dev:preload": "tsup src/preload/index.ts --format cjs --out-dir dist/preload --watch --silent --external electron",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "dev:app": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "node scripts/build.mjs",
    "build:legacy": "npm run clean && npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsup src/main/index.ts --format cjs --out-dir dist/main --external electron --external better-sqlite3 --external sharp --external canvas --external @tensorflow/tfjs-backend-wasm --external @tensorflow/tfjs --external @vladmandic/face-api --external electron-updater --external fs-extra --external uuid",
    "build:preload": "tsup src/preload/index.ts --format cjs --out-dir dist/preload --external electron --external electron-updater",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "clean": "rimraf dist out",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "release:check": "node scripts/release-check.mjs",
    "dist:win": "npm run build && electron-builder --win nsis:x64",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "release:check-sign": "node -e \"const required=['CSC_LINK','CSC_KEY_PASSWORD']; const missing=required.filter((key)=>!process.env[key]); if (missing.length) { console.log('⚠️ 尚未設定 Windows 程式碼簽章環境變數: '+missing.join(', ')); console.log('請在發佈前設定憑證後再使用 release:win:with-sign。'); } else { console.log('✅ 偵測到簽章環境，將在發佈時自動套用。'); }\"",
    "release:win": "npm run release:check && npm run dist:win",
    "release:win:with-sign": "npm run release:check && npm run release:check-sign && npm run dist:win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.local.dahailao-b",
    "productName": "大海撈Ｂ",
    "copyright": "Copyright © 2024",
    "icon": "resources/logo_new.png",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "package.json",
      "node_modules/**",
      "!node_modules/**/{test,tests,__tests__,docs,examples,example,doc}/**",
      "!node_modules/**/*.md",
      "!**/*.test.ts",
      "!**/*.test.tsx",
      "!tests/**",
      "!node_modules/@tensorflow/tfjs-node/**",
      "!node_modules/@tensorflow/tfjs-node-gpu/**",
      "!node_modules/canvas/**/build-tmp-napi-v*/**",
      "!node_modules/@vladmandic/face-api/dist/face-api.node.js"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/sharp/**",
      "node_modules/canvas/**",
      "node_modules/@vladmandic/**",
      "node_modules/@tensorflow/tfjs/**",
      "node_modules/@tensorflow/tfjs-core/**",
      "node_modules/@tensorflow/tfjs-layers/**",
      "node_modules/@tensorflow/tfjs-converter/**",
      "node_modules/@tensorflow/tfjs-backend-cpu/**",
      "node_modules/@tensorflow/tfjs-backend-wasm/**",
      "node_modules/@tensorflow/tfjs-backend-webgl/**",
      "node_modules/@tensorflow/tfjs-data/**",
      "node_modules/seedrandom/**",
      "node_modules/long/**",
      "node_modules/electron-updater/**"
    ],
    "extraResources": [
      {
        "from": "resources/logo_new.png",
        "to": "logo_new.png"
      }
    ],
    "win": {
      "icon": "resources/logo_new.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "da-hai-lao-b-${version}-Setup.${ext}",
      "publisherName": "Local Developer"
    },
    "mac": {
      "icon": "resources/logo_new.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.photography",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "icon": "resources/logo_new.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "samulee003",
        "repo": "child-picture-select"
      }
    ],
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "大海撈Ｂ"
    },
    "extraMetadata": {
      "main": "dist/main/index.cjs"
    }
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@tensorflow/tfjs-layers": "^4.22.0",
    "@vladmandic/face-api": "^1.7.12",
    "better-sqlite3": "^11.7.0",
    "canvas": "^3.2.1",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.3",
    "long": "^5.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^2.2.7",
    "seedrandom": "^3.0.5",
    "sharp": "^0.33.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.5.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "icon-gen": "^5.0.0",
    "jsdom": "^28.1.0",
    "node-gyp": "^11.5.0",
    "node-releases": "^2.0.27",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "svg-to-ico": "^1.1.0",
    "svg2ico": "^1.0.35",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "wait-on": "^8.0.2"
  }
}
